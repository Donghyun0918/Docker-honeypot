# Docker Honeypot Lab - 환경 설정 템플릿
# 사용법: cp .env.example .env  →  .env를 본인 환경에 맞게 수정

COMPOSE_PROJECT_NAME=honeypot

# 로그 저장 경로 (WSL2: /mnt/<드라이브>/honeypot_logs)
HONEYPOT_LOGS=/mnt/d/honeypot_logs

# 내부 네트워크 서브넷
SUBNET=172.30.0.0/24

# 컨테이너 고정 IP
COWRIE_IP=172.30.0.10
HERALDING_IP=172.30.0.11
OPENCANARY_IP=172.30.0.12
SNARE_IP=172.30.0.13
DIONAEA_IP=172.30.0.14
MAILONEY_IP=172.30.0.15
CONPOT_IP=172.30.0.16
TANNER_IP=172.30.0.17
KALI_IP=172.30.0.20
