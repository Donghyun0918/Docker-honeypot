# ── 경로 설정 ─────────────────────────────────────────────────────────────────
# 프로젝트 루트 (클론한 경로)
# Windows: D:/docker_honeypot  |  Linux: /opt/honeyforge
PROJECT_HOST=D:/docker_honeypot

# 로그 저장 경로
# Windows: D:/honeypot_logs  |  Linux: /opt/honeypot_logs
HONEYPOT_LOGS_HOST=D:/honeypot_logs

# ── 보안 (반드시 변경) ───────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── 네트워크 (기본값 그대로 사용 가능) ───────────────────────────────────────
SUBNET=172.30.0.0/24
COWRIE_IP=172.30.0.10
HERALDING_IP=172.30.0.11
OPENCANARY_IP=172.30.0.12
SNARE_IP=172.30.0.13
DIONAEA_IP=172.30.0.14
MAILONEY_IP=172.30.0.15
CONPOT_IP=172.30.0.16
TANNER_IP=172.30.0.17
KALI_IP=172.30.0.20
